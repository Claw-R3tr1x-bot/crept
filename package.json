{
  "name": "crept",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "website/backend",
    "website/frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace website/backend run dev",
    "dev:frontend": "npm --workspace website/frontend run dev",
    "build": "npm --workspace website/backend run build && npm --workspace website/frontend run build",
    "start": "npm --workspace website/backend run start",
    "seed": "npm --workspace website/backend run seed",
    "lint": "npm --workspace website/backend run lint && npm --workspace website/frontend run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
